# Set the port to your server
PORT=3000
# Local Postgres: use localhost. Docker Compose backend: hostname is "postgres" (set automatically in compose).
# Example: DATABASE_URL=postgresql://demouser:''@localhost:5432/demo
DATABASE_URL=postgresql://[user]:[password]@localhost:5432/[database]
# Create a 256-bits long string and add it as jwt secret
JWT_SECRET=a-string-secret-at-least-256-bits-long

# Docker Compose: set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB to match DATABASE_URL.

# Bind address (use 0.0.0.0 in Docker; default without env is 127.0.0.1)
# LISTEN_HOST=0.0.0.0

# From CrossListr backend -> emulators (Docker DNS on crosslistr-emulators-integration)
# FAKEBAY_AUTH_URL=http://fakebay-backend:8081
# FAKEBAY_API_URL=http://fakebay-backend:8082
# FAKIFY_API_URL=http://fakify-backend:8080
# FAKETSY_API_URL=http://faketsy-backend:8082
